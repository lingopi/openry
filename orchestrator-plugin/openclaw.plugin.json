{
  "id": "orchestrator-plugin",
  "name": "OpenRY Orchestrator",
  "description": "OpenRY workflow orchestration: openry_run (command execution) and openry_status (state declaration) tools for OpenClaw agents.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "openryDir": {
        "type": "string",
        "description": "Path to the .openry directory. Default: ~/.openry"
      }
    }
  },
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": ["openry_run", "openry_status"]
  }
}
